# Backend + Integrationstests (server/, Vitest: server/tests/auth.test.ts)
# Postgres mit angewendetem server/db/schema.sql
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seo_workflow
JWT_SECRET=dev-secret-mindestens-32-zeichen-lang-setzen
APP_URL=http://localhost:5173
RESEND_API_KEY=
EMAIL_FROM=

# Markdown-Uploads fuer Link Graph (SP22): absolut oder relativ zum Server-Arbeitsverzeichnis.
# Verzeichnis muss beschreibbar sein; fuer NAS-Verzeichnis per Mount hier einbinden.
UPLOAD_ROOT=./uploads

# Backend-Port (Express). Vite leitet /api dorthin weiter (vite.config.ts).
# Standard 3003 — bewusst nicht 3001, damit parallel Velacare (next dev -p 3001) laufen kann.

# Docker (fuer docker-compose)
# DB_PASSWORD wird in docker-compose.yml fuer den Postgres-Container verwendet
# JWT_SECRET wird auch in docker-compose.yml fuer den App-Container verwendet
DB_PASSWORD=changeme
PORT=3003
CORS_ORIGIN=https://your-domain.com

# Refresh-Cookie: bei http:// (Docker lokal) COOKIE_SECURE=false setzen. Mit HTTPS in Production weglassen oder true.
# COOKIE_SECURE=false

# Optional: kommagetrennte E-Mails, die immer als Superadmin gelten (UI + /api/admin/*).
# Nützlich wenn Production-DB-Flag und Erwartung auseinanderlaufen — trotzdem nur mit vertrauenswürdigen Adressen setzen.
# SUPERADMIN_EMAILS=admin@firma.de,zweiter@firma.de
#
# NAS / Production: Diese Variable im .env auf dem Server setzen, damit der Superadmin-Zugang
# unabhängig vom DB-Flag funktioniert (z.B. nach einem Neuaufbau der Datenbank):
# SUPERADMIN_EMAILS=d.feferman@adebo-medical.de
