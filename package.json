    "@tanstack/router-devtools": "^1.78.0",
    "@tanstack/router-vite-plugin": "^1.78.0",
    "@xyflow/react": "^12.10.2",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
