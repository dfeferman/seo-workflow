{
  "name": "seo-workflow-platform",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run server:build",
    "lint": "eslint .",
    "preview": "vite preview",
